local nextbotNames = {}

if ReplicatedStorage:FindFirstChild("NPCs") then
    for _,npc in ipairs(ReplicatedStorage.NPCs:GetChildren()) do
        table.insert(nextbotNames,npc.Name)
    end
end

local nextbotKeywords = {
    "nextbot",
    "nextbots",
    "scp",
    "monster",
    "creep",
    "zombie",
    "ghost",
    "demon"
}

local function isNextbot(model)

    if not model or not model:IsA("Model") then
        return false
    end

    if Players:GetPlayerFromCharacter(model) then
        return false
    end

    if table.find(nextbotNames,model.Name) then
        return true
    end

    local lowerName = model.Name:lower()

    for _,kw in ipairs(nextbotKeywords) do
        if lowerName:find(kw) then
            return true
        end
    end

    if model:FindFirstChild("HumanoidRootPart") and not model:FindFirstChild("Humanoid") then
        return true
    end

    return false
end

local function destroyNametag(target)

    if nametagCache[target] then
        pcall(function()
            nametagCache[target]:Destroy()
        end)

        nametagCache[target] = nil
    end
end

local function clearAllNametags()

    for target in pairs(nametagCache) do
        destroyNametag(target)
    end

    nametagCache = {}

    for _,gui in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do
        if gui.Name == "VexNametag" then
            pcall(gui.Destroy,gui)
        end
    end
end

local function removeTracer(tbl,key)

    local tracer = tbl[key]

    if tracer then
        tracer.Visible = false
        pcall(tracer.Remove,tracer)
        tbl[key] = nil
    end
end

local function clearTracers(tbl)

    for key in pairs(tbl) do
        removeTracer(tbl,key)
    end
end

local function createNametag(target,text,color)

    if not target.Parent then
        return
    end

    local root = target:FindFirstChild("HumanoidRootPart") or target.PrimaryPart

    if not root then
        return
    end

    destroyNametag(target)

    local bbg = Instance.new("BillboardGui")
    bbg.Name = "VexNametag"
    bbg.Adornee = root
    bbg.Size = UDim2.new(0,120,0,30)
    bbg.StudsOffset = Vector3.new(0,3,0)
    bbg.AlwaysOnTop = true
    bbg.ResetOnSpawn = false
    bbg.Parent = root.Parent

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1,0,1,0)
    label.Font = Enum.Font.GothamBold
    label.Text = text
    label.TextColor3 = color
    label.TextScaled = true
    label.TextStrokeTransparency = 0.6
    label.TextStrokeColor3 = Color3.new(0,0,0)
    label.Parent = bbg

    nametagCache[target] = bbg
end

local function createTracer()

    local t = Drawing.new("Line")

    t.Visible = false
    t.Thickness = 1.5
    t.Transparency = 1
    t.ZIndex = 2

    return t
end

RunService.RenderStepped:Connect(function()

    local cam = workspace.CurrentCamera
    if not cam then return end

    local bottomCenter = Vector2.new(
        cam.ViewportSize.X/2,
        cam.ViewportSize.Y
    )

    if getgenv().PlayerTracers then

        local active = {}

        for _,plr in ipairs(Players:GetPlayers()) do

            if plr ~= LocalPlayer and plr.Character then

                local hrp = plr.Character:FindFirstChild("HumanoidRootPart")

                if hrp then

                    active[plr] = true

                    if not playerTracerElements[plr] then
                        playerTracerElements[plr] = createTracer()
                    end

                    local tracer = playerTracerElements[plr]

                    local screenPos,onScreen = cam:WorldToViewportPoint(hrp.Position)

                    tracer.Visible = onScreen

                    if onScreen then
                        tracer.From = bottomCenter
                        tracer.To = Vector2.new(screenPos.X,screenPos.Y)
                        tracer.Color = Color3.fromRGB(200,220,255)
                    end
                end
            end
        end

        for plr in pairs(playerTracerElements) do
            if not active[plr] then
                removeTracer(playerTracerElements,plr)
            end
        end
    end

    if getgenv().NextbotTracers then

        local active = {}
        local folders = {}

        if workspace.Game and workspace.Game:FindFirstChild("Players") then
            table.insert(folders,workspace.Game.Players)
        end

        if workspace:FindFirstChild("NPCs") then
            table.insert(folders,workspace.NPCs)
        end

        if #folders == 0 then
            table.insert(folders,workspace)
        end

        for _,folder in ipairs(folders) do

            for _,obj in ipairs(folder:GetDescendants()) do

                if obj:IsA("Model") and isNextbot(obj) then

                    local hrp = obj:FindFirstChild("HumanoidRootPart") or obj.PrimaryPart

                    if hrp then

                        active[obj] = true

                        if not botTracerElements[obj] then
                            botTracerElements[obj] = createTracer()
                        end

                        local tracer = botTracerElements[obj]

                        local screenPos,onScreen = cam:WorldToViewportPoint(hrp.Position)

                        tracer.Visible = onScreen

                        if onScreen then
                            tracer.From = bottomCenter
                            tracer.To = Vector2.new(screenPos.X,screenPos.Y)
                            tracer.Color = Color3.fromRGB(255,70,70)
                        end
                    end
                end
            end
        end

        for bot in pairs(botTracerElements) do
            if not active[bot] or not bot.Parent then
                removeTracer(botTracerElements,bot)
            end
        end
    end
end)

local function startAutoRevivePlayer()

    if getgenv().AutoRevivePlayerActive then return end

    getgenv().AutoRevivePlayerActive = true

    task.spawn(function()

        while getgenv().AutoRevivePlayerActive do

            task.wait(0.1)

            pcall(function()

                local myChar = LocalPlayer.Character
                local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")

                if not myHrp then return end

                local playersFolder = workspace.Game and workspace.Game:FindFirstChild("Players")
                if not playersFolder then return end

                for _,model in ipairs(playersFolder:GetChildren()) do

                    if model:IsA("Model")
                    and model.Name ~= LocalPlayer.Name
                    and model:GetAttribute("Downed") then

                        local downedHrp = model:FindFirstChild("HumanoidRootPart")

                        if downedHrp then

                            myHrp.CFrame = downedHrp.CFrame + Vector3.new(0,2.5,0)

                            task.wait(0.12)

                            ReplicatedStorage.Events.Character.Interact:FireServer(
                                "Revive",
                                true,
                                model.Name
                            )

                            task.wait(0.08)

                            local prompt = model:FindFirstChildWhichIsA("ProximityPrompt",true)

                            if prompt then
                                fireproximityprompt(prompt)
                            end

                            task.wait(0.5)

                            break
                        end
                    end
                end
            end)
        end
    end)
end

local function stopAutoRevivePlayer()
    getgenv().AutoRevivePlayerActive = false
end

